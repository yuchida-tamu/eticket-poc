APP_NAME="eticket-poc backend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database — Postgres (see CLAUDE.md). Tests run on SQLite :memory: via phpunit.xml.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=eticket
DB_USERNAME=eticket
DB_PASSWORD=

SESSION_DRIVER=database
QUEUE_CONNECTION=sync
CACHE_STORE=database

# spatie/laravel-mobile-pass — Apple Wallet (fill in for real pass issuance; not needed for the health endpoint)
MOBILE_PASS_APPLE_CERTIFICATE=
MOBILE_PASS_APPLE_CERTIFICATE_PATH=
MOBILE_PASS_APPLE_CERTIFICATE_PASSWORD=
MOBILE_PASS_APPLE_TEAM_IDENTIFIER=
MOBILE_PASS_APPLE_TYPE_IDENTIFIER=
MOBILE_PASS_APPLE_ORGANIZATION_NAME="eticket-poc"
MOBILE_PASS_APPLE_WEBSERVICE_HOST=
MOBILE_PASS_APPLE_WEBSERVICE_SECRET=

# spatie/laravel-mobile-pass — Google Wallet (unused in this POC)
MOBILE_PASS_GOOGLE_ISSUER_ID=
MOBILE_PASS_GOOGLE_KEY=
MOBILE_PASS_GOOGLE_KEY_PATH=

MOBILE_PASS_QUEUE_CONNECTION=
MOBILE_PASS_QUEUE_NAME=

# eticket pass issuance (POST /api/passes)
ETICKET_SERIAL_PREFIX=ETK
# Optional: base64 (DER) P-256 PUBLIC key for the NFC payload.
# Defaults to the committed asset resources/passes/nfc_public_key.b64 when unset.
ETICKET_NFC_PUBLIC_KEY=
